# 1. Χρησιμοποιούμε μια ελαφριά έκδοση της Python
FROM python:3.11-slim

# 2. Ορίζουμε τον φάκελο εργασίας μέσα στο container
WORKDIR /app

# 3. Αντιγράφουμε το αρχείο με τις βιβλιοθήκες
COPY requirements.txt .

# 4. Εγκαθιστούμε τις βιβλιοθήκες
RUN pip install --no-cache-dir -r requirements.txt

# 5. Αντιγράφουμε όλο τον κώδικα (το main.py και ό,τι άλλο υπάρχει)
COPY . .

# 6. Ενημερώνουμε το Docker ότι το API μας ακούει στην πόρτα 5698
# (Αν τελικά κρατήσεις την 8000, άλλαξέ το σε 8000)
EXPOSE 5698

# 7. Η εντολή για να ξεκινήσει το API
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "7860"]